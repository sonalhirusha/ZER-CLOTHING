# ZERØ CLOTHING API — PRODUCTION env template (Supabase + Resend stack)
# Copy to your host's environment variables. DO NOT commit real secrets.
# See ../DEPLOY.md for the full runbook.

# ---- Server ----
NODE_ENV=production
PORT=4000
APP_URL=https://zero-clothing-api.onrender.com          # your deployed API URL
SITE_URL=https://sonalhirusha.github.io/ZER-CLOTHING     # your storefront URL
CORS_ORIGINS=https://sonalhirusha.github.io              # comma-separated allowed origins

# ---- Database (Supabase PostgreSQL) ----
# Supabase -> Project Settings -> Database -> Connection string
# Pooled (Transaction, port 6543) for the app; Direct (port 5432) for migrations.
# NOTE: also set datasource provider="postgresql" + directUrl in prisma/schema.prisma (see DEPLOY.md section 4).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Auth / JWT (generate long random strings) ----
JWT_ACCESS_SECRET=__REPLACE_WITH_LONG_RANDOM__
JWT_REFRESH_SECRET=__REPLACE_WITH_ANOTHER_LONG_RANDOM__
JWT_ADMIN_SECRET=__REPLACE_WITH_A_THIRD_LONG_RANDOM__
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL_DAYS=30

# ---- Email (Resend over SMTP) ----
# Resend -> API Keys (use the key as the SMTP password; username is literally "resend").
# EMAIL_FROM domain MUST be a Resend-verified domain.
EMAIL_FROM="ZERO CLOTHING <orders@zeroclothing.lk>"
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=__RESEND_API_KEY__

# ---- Uploads ----
# Disk (default; works on Render via the mounted disk in render.yaml):
UPLOAD_DIR=/var/data/uploads
UPLOAD_MAX_BYTES=10485760
# Supabase Storage (only if you add the storage adapter — see DEPLOY.md section 8):
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=__SERVICE_ROLE_KEY__
# SUPABASE_BUCKET_RECEIPTS=receipts
# SUPABASE_BUCKET_ARTWORK=artwork

# ---- Payments (optional gateway; built-in card/bank + receipt-upload flow works without it) ----
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=live

# ---- Seed admin (created by `node prisma/seed.js`) ----
SEED_ADMIN_EMAIL=admin@zeroclothing.lk
SEED_ADMIN_PASSWORD=__STRONG_ADMIN_PASSWORD__
