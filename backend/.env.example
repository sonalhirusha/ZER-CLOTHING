# ZERØ CLOTHING API — environment template. Copy to .env and fill in.
# Everything has a working dev default, so the API runs out of the box with SQLite.

# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
SITE_URL=http://localhost:8080
# Comma-separated frontend origins allowed by CORS. Empty = allow all (dev).
CORS_ORIGINS=

# Database
# SQLite (default, zero-config):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production) — switch provider in prisma/schema.prisma to "postgresql":
# DATABASE_URL="postgresql://user:pass@host:5432/zero_clothing?schema=public"

# Auth / JWT  (CHANGE THESE IN PRODUCTION)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ADMIN_SECRET=change-me-to-a-third-long-random-string
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL_DAYS=30

# Uploads
UPLOAD_DIR=
UPLOAD_MAX_BYTES=10485760

# Email (SMTP). Leave SMTP_HOST blank in dev to write .eml previews to var/mail.
EMAIL_FROM="ZERO CLOTHING <orders@zeroclothing.lk>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Payments (PayHere — optional). Leave blank to use the built-in card/bank flow.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=sandbox

# Seed admin (created by `npm run seed`)
SEED_ADMIN_EMAIL=admin@zeroclothing.lk
SEED_ADMIN_PASSWORD=Admin123!
