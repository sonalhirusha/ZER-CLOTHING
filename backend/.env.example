# ZERØ CLOTHING API — environment template. Copy to .env and fill in.

# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins (CORS allowlist)
CORS_ORIGINS=http://localhost:5173,https://sonalhirusha.github.io

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zero_clothing?schema=public

# Auth / JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Email provider (Resend / SES) — used by the email worker
EMAIL_PROVIDER=resend
EMAIL_FROM="ZERO CLOTHING <orders@zeroclothing.lk>"
RESEND_API_KEY=

# Object storage (S3 / R2) — artwork, receipts, labels
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=zero-clothing-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Payments (PayHere — Sri Lanka)
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=sandbox

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Redis (sessions, rate limit, job queue)
REDIS_URL=redis://localhost:6379
